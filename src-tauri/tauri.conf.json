{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Git Switch",
  "version": "0.1.0",
  "identifier": "com.scottcarey.git-switch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Git Switch",
        "width": 480,
        "height": 512,
        "resizable": false,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "backgroundColor": "#07090d"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Manage multiple git identities",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
